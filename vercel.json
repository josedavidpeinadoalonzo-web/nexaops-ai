{
  "name": "nexaops-ai",
  "version": 2,
  "builds": [
    {
      "src": "api/server.js",
      "use": "@vercel/node"
    },
    {
      "src": "public/**",
      "use": "@vercel/static"
    },
    {
      "src": "admin/**",
      "use": "@vercel/static"
    }
  ],
  "routes": [
    {
      "src": "/api/(.*)",
      "dest": "/api/server.js"
    },
    {
      "src": "/login",
      "dest": "/public/login.html"
    },
    {
      "src": "/admin/(.*)",
      "headers": { "X-Robots-Tag": "noindex" },
      "dest": "/admin/$1"
    },
    {
      "src": "/dashboard",
      "dest": "/admin/dashboard.html"
    },
    {
      "src": "/portal",
      "dest": "/admin/portal.html"
    },
    {
      "src": "/(.*)",
      "dest": "/public/$1"
    }
  ]
}
